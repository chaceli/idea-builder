<view class="schedule-container data-v-65374328"><view class="header data-v-65374328"><text class="title data-v-65374328">日程提醒</text><view class="add-btn data-v-65374328" bindtap="{{a}}"><text class="data-v-65374328">+</text></view></view><view class="section data-v-65374328"><text class="section-title data-v-65374328">今天</text><view wx:if="{{b}}" class="empty data-v-65374328"><text class="data-v-65374328">今天没有日程哦~</text></view><view wx:else class="schedule-list data-v-65374328"><view wx:for="{{c}}" wx:for-item="item" wx:key="f" class="schedule-item data-v-65374328"><view class="schedule-content data-v-65374328"><text class="schedule-title data-v-65374328">{{item.a}}</text><text class="schedule-time data-v-65374328">{{item.b}}</text></view><view class="schedule-actions data-v-65374328"><view wx:if="{{item.c}}" class="check-btn data-v-65374328" bindtap="{{item.d}}"><text class="data-v-65374328">✓</text></view><view class="delete-btn data-v-65374328" bindtap="{{item.e}}"><text class="data-v-65374328">✕</text></view></view></view></view></view><view class="section data-v-65374328"><text class="section-title data-v-65374328">未来</text><view wx:if="{{d}}" class="empty data-v-65374328"><text class="data-v-65374328">没有未来的日程~</text></view><view wx:else class="schedule-list data-v-65374328"><view wx:for="{{e}}" wx:for-item="item" wx:key="d" class="schedule-item data-v-65374328"><view class="schedule-content data-v-65374328"><text class="schedule-title data-v-65374328">{{item.a}}</text><text class="schedule-time data-v-65374328">{{item.b}}</text></view><view class="schedule-actions data-v-65374328"><view class="delete-btn data-v-65374328" bindtap="{{item.c}}"><text class="data-v-65374328">✕</text></view></view></view></view></view><view wx:if="{{f}}" class="modal-mask data-v-65374328" bindtap="{{q}}"><view class="modal data-v-65374328" catchtap="{{p}}"><text class="modal-title data-v-65374328">添加日程</text><input class="modal-input data-v-65374328" placeholder="日程标题" value="{{g}}" bindinput="{{h}}"/><input class="modal-input data-v-65374328" placeholder="备注（可选）" value="{{i}}" bindinput="{{j}}"/><view class="modal-time data-v-65374328"><text class="data-v-65374328">提醒时间：</text><picker class="data-v-65374328" mode="time" value="{{l}}" bindchange="{{m}}"><text class="data-v-65374328">{{k}}</text></picker></view><view class="modal-actions data-v-65374328"><view class="cancel-btn data-v-65374328" bindtap="{{n}}">取消</view><view class="confirm-btn data-v-65374328" bindtap="{{o}}">确定</view></view></view></view></view>